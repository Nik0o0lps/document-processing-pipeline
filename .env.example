# LLM Provider: "openai" ou "groq"
LLM_PROVIDER=groq

# OpenAI Configuration (se usar LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Groq Configuration (se usar LLM_PROVIDER=groq) - GRATUITO!
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Processing configuration
MAX_RETRIES=3
TIMEOUT_SECONDS=30

# OCR Configuration (opcional - usa defaults se não especificado)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# POPPLER_PATH=C:\poppler-25.12.0\Library\bin
